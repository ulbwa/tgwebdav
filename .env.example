# tgwebdav configuration example — copy to .env and fill in your values.
# All values can also be passed as command-line flags (see --help).

# PostgreSQL DSN (required)
TGWEBDAV_DSN=postgres://tgwebdav:tgwebdav@localhost:5432/tgwebdav?sslmode=disable

# Listen addresses (optional; defaults shown)
TGWEBDAV_WEBDAV_ADDR=:8080
TGWEBDAV_MGMT_ADDR=:8081

# Disk blob cache (optional; defaults: user cache dir, 1GiB)
# TGWEBDAV_CACHE_DIR=/var/cache/tgwebdav
# TGWEBDAV_CACHE_SIZE=1GiB

# Bootstrap administrator, created only when the users table is empty.
# Format: login:password
TGWEBDAV_FIRST_USER=admin:change-me-please

# Secret used to derive the AES-256-GCM key that encrypts bot tokens at rest.
# Required whenever bot tokens are configured. Use a long random value.
TGWEBDAV_SECRET_KEY=replace-with-a-long-random-secret

# Telegram bot tokens to seed, comma separated.
TGWEBDAV_BOT_TOKENS=123456:AA...,234567:BB...

# Telegram channel bare ids to seed, comma separated.
# (The Bot API -100 prefix is applied internally.)
TGWEBDAV_CHANNEL_IDS=4298072562,3709844713

# Log level: debug|info|warn|error (optional; default info)
TGWEBDAV_LOG_LEVEL=info
